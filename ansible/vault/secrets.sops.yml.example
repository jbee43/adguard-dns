---
# Vault secrets template. Copy to secrets.sops.yml, edit the values below,
# then encrypt in place:
#
#   sops --encrypt --in-place ansible/vault/secrets.sops.yml
#
# .sops.yaml is what tells SOPS which age public key to encrypt for.
#
# Generate the AdGuard admin password hash with:
#   htpasswd -nbBC 10 "" "YourPasswordHere" | cut -d: -f2

vault_adguard_admin_password_hash: "$2y$10$REPLACE_WITH_BCRYPT_HASH"

# Only required if enable_zabbix_agent: true
vault_zabbix_server: "192.0.2.30"
